{
  "name": "24hourclipping",
  "version": "1.0.0",
  "private": true,
  "description": "24 Hour Clipping — full-stack monorepo (FastAPI + MongoDB backend, React frontend).",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "setup": "npm run setup:backend && npm run setup:frontend",
    "setup:backend": "cd backend && pip install -r requirements-core.txt",
    "setup:frontend": "cd frontend && yarn install",
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "cd backend && uvicorn server:app --reload --host 0.0.0.0 --port 8001",
    "dev:frontend": "cd frontend && yarn start",
    "build": "cd frontend && yarn build",
    "test:backend": "cd backend && pytest",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
