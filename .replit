modules = ["nodejs-20", "python-3.12", "web", "bash"]

# MONOREPO: backend/ = FastAPI + Postgres, frontend/ = React (CRA + CRACO).
# This Repl runs the FULL STACK locally against the Repl's own Postgres, so it is
# a completely isolated sandbox - nothing here can touch production data.
#
#   Import repo  ->  Tools > PostgreSQL (one click)  ->  press Run.
#
# The script installs deps on first run only, then boots FastAPI on :8001 and the
# React dev server on :3000, which proxies /api -> :8001 (same single-origin
# setup nginx gives us in production). Only :3000 is exposed publicly.
run = "bash scripts/replit-start.sh"

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[env]
# --- API wiring -------------------------------------------------------------
# REACT_APP_BACKEND_URL is deliberately UNSET so the app calls same-origin /api,
# which the dev server proxies to the local backend (see craco.config.js).
PROXY_API = "http://127.0.0.1:8001"

# --- Backend (local sandbox) ------------------------------------------------
# Lets auth.py use a throwaway dev signing key instead of refusing to boot.
# NEVER set ENV=development in production - that's what keeps prod fail-closed.
ENV = "development"
# No S3 in the Repl: media falls back to local disk.
MEDIA_ROOT = ".media"
# Post jobs without paying, so the full flow is exercisable end-to-end.
FREE_POSTING = "true"
SEED_DEMO_DATA = "true"
# Optional: add OPENAI_API_KEY in Tools > Secrets to enable the AI concierge.
# Everything else (auth, projects, bids, contracts, messaging, uploads) works
# without any secret at all.

# --- Dev server -------------------------------------------------------------
HOST = "0.0.0.0"
PORT = "3000"
# The "Invalid Host header" problem is solved in craco.config.js by allow-listing
# *.replit.dev when REPL_ID is set - deliberately NOT by setting
# DANGEROUSLY_DISABLE_HOST_CHECK, which would disable the dev server's
# DNS-rebinding protection for every developer, everywhere.
WDS_SOCKET_PORT = "443"
BROWSER = "none"

[[ports]]
localPort = 3000
externalPort = 80
