# ---- Backend environment ----
# Copy to backend/.env and fill in values.

# MongoDB connection string.
# Local:            mongodb://localhost:27017
# Docker Compose:   mongodb://mongo:27017
MONGO_URL=mongodb://localhost:27017

# Database name used by the app.
DB_NAME=clipping

# Comma-separated list of allowed CORS origins ("*" allows all).
CORS_ORIGINS=*

# ---- Auth (required) ----
# Secret used to sign JWTs. MUST be set to a long random value in production.
# Generate one with:  openssl rand -hex 32
SECRET_KEY=
# How long access tokens stay valid (minutes). Default 7 days.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Real admin account, provisioned on startup. Without these, no admin exists.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Demo one-click login. Keep customer/clipper demo on for showcasing; admin demo
# stays OFF so the admin console is only reachable with the real password above.
ENABLE_DEMO_LOGIN=true
ENABLE_DEMO_ADMIN=false

# Seed demo marketplace data on first boot.
SEED_DEMO_DATA=true

# Optional: Google Sign-In. Get a Web OAuth client ID from Google Cloud Console.
# Leave blank to disable Google auth (email/password still works).
GOOGLE_CLIENT_ID=

# Optional: enables the AI concierge / brief endpoints (/api/ai/*).
# Requires the Emergent integrations package. Leave blank to disable AI.
EMERGENT_LLM_KEY=
